  <rect x="60" y="110" width="10" height="10" fill="white"/>
  <rect x="80" y="110" width="10" height="10" fill="white"/>
  <rect x="100" y="110" width="10" height="10" fill="white"/>
  <rect x="120" y="110" width="10" height="10" fill="white"/>
